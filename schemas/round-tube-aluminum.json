{
  "id": "round-tube-aluminum",
  "name": "Aluminum Round Tube",
  "version": "1.0.0",
  "description": "6063-T5 aluminum round tube",
  "parameters": {
    "od": {
      "label": "Outer Diameter",
      "default": 20,
      "min": 4,
      "max": 80,
      "step": 1,
      "unit": "mm",
      "group": "dimensions"
    },
    "wall": {
      "label": "Wall Thickness",
      "default": 2,
      "min": 0.5,
      "max": 10,
      "step": 0.5,
      "unit": "mm",
      "group": "dimensions"
    },
    "length": {
      "label": "Length",
      "default": 50,
      "min": 10,
      "max": 300,
      "step": 5,
      "unit": "mm",
      "group": "dimensions"
    }
  },
  "derived": {
    "outer_radius": {
      "formula": "od / 2",
      "description": "Outer radius"
    },
    "inner_radius": {
      "formula": "od / 2 - wall",
      "description": "Inner radius"
    }
  },
  "geometry": {
    "body": {
      "type": "cylinder",
      "radius": "outer_radius",
      "height": "length",
      "bore": "inner_radius",
      "segments": 32
    }
  },
  "groups": {
    "dimensions": {
      "label": "Dimensions",
      "order": 1
    }
  },
  "presets": {
    "default": {
      "label": "Default",
      "values": {}
    }
  }
}