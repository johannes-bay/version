{
  "id": "hex-nut",
  "name": "ISO Hex Nut",
  "version": "1.0.0",
  "description": "ISO 4032 hexagonal nut",

  "parameters": {
    "size": {
      "label": "Metric Size",
      "type": "select",
      "options": ["M3", "M4", "M5", "M6", "M8", "M10", "M12"],
      "default": "M6",
      "group": "dimensions"
    }
  },

  "derived": {
    "pitch": {
      "formula": "ISO_PITCH[size]",
      "description": "Thread pitch from ISO standard"
    },
    "major_diameter": {
      "formula": "ISO_MAJOR[size]",
      "description": "Major (nominal) diameter"
    },
    "nut_width_af": {
      "formula": "ISO_NUT_AF[size]",
      "description": "Width across flats"
    },
    "nut_height": {
      "formula": "ISO_NUT_HEIGHT[size]",
      "description": "Nut height"
    },
    "outer_radius": {
      "formula": "nut_width_af / sqrt(3)",
      "description": "Circumscribed radius (center to vertex)"
    },
    "bore_radius": {
      "formula": "major_diameter / 2",
      "description": "Thread bore radius"
    }
  },

  "constants": {
    "ISO_PITCH": { "M3": 0.5, "M4": 0.7, "M5": 0.8, "M6": 1.0, "M8": 1.25, "M10": 1.5, "M12": 1.75 },
    "ISO_MAJOR": { "M3": 3.0, "M4": 4.0, "M5": 5.0, "M6": 6.0, "M8": 8.0, "M10": 10.0, "M12": 12.0 },
    "ISO_NUT_AF": { "M3": 5.5, "M4": 7.0, "M5": 8.0, "M6": 10.0, "M8": 13.0, "M10": 16.0, "M12": 18.0 },
    "ISO_NUT_HEIGHT": { "M3": 2.4, "M4": 3.2, "M5": 4.7, "M6": 5.2, "M8": 6.8, "M10": 8.4, "M12": 10.8 }
  },

  "geometry": {
    "body": {
      "type": "polygon",
      "sides": 6,
      "radius": "outer_radius",
      "height": "nut_height",
      "bore": "bore_radius"
    }
  },

  "groups": {
    "dimensions": { "label": "Dimensions", "order": 1 }
  },

  "presets": {
    "m4": { "label": "M4", "values": { "size": "M4" } },
    "m6": { "label": "M6", "values": { "size": "M6" } },
    "m8": { "label": "M8", "values": { "size": "M8" } },
    "m10": { "label": "M10", "values": { "size": "M10" } }
  }
}
