{
  "id": "metric-clevis-pin",
  "name": "Metric Clevis Pin",
  "version": "1.0.0",
  "description": "Clevis pin with head",
  "parameters": {
    "diameter": {
      "label": "Diameter",
      "type": "select",
      "options": [
        "1",
        "1.5",
        "2",
        "2.5",
        "3",
        "4",
        "5",
        "6",
        "8",
        "10",
        "12"
      ],
      "default": "6",
      "group": "dimensions"
    },
    "length": {
      "label": "Length",
      "default": 20,
      "min": 5,
      "max": 100,
      "step": 1,
      "unit": "mm",
      "group": "dimensions"
    }
  },
  "derived": {
    "pin_diameter": {
      "formula": "PIN_DIA[diameter]",
      "description": "Pin diameter"
    },
    "radius": {
      "formula": "pin_diameter / 2",
      "description": "Pin radius"
    },
    "head_radius": {
      "formula": "radius * 1.5",
      "description": "Head radius"
    },
    "head_height": {
      "formula": "pin_diameter * 0.3",
      "description": "Head height"
    }
  },
  "constants": {
    "PIN_DIA": {
      "1": 1.0,
      "1.5": 1.5,
      "2": 2.0,
      "2.5": 2.5,
      "3": 3.0,
      "4": 4.0,
      "5": 5.0,
      "6": 6.0,
      "8": 8.0,
      "10": 10.0,
      "12": 12.0
    }
  },
  "geometry": {
    "shaft": {
      "type": "cylinder",
      "radius": "radius",
      "height": "length",
      "position": [
        0,
        "-length / 2",
        0
      ]
    },
    "head": {
      "type": "cylinder",
      "radius": "head_radius",
      "height": "head_height",
      "position": [
        0,
        "head_height / 2",
        0
      ]
    }
  },
  "groups": {
    "dimensions": {
      "label": "Dimensions",
      "order": 1
    }
  },
  "presets": {
    "d6x20": {
      "label": "6x20",
      "values": {
        "diameter": "6",
        "length": 20
      }
    },
    "d8x30": {
      "label": "8x30",
      "values": {
        "diameter": "8",
        "length": 30
      }
    }
  }
}