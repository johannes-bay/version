{
  "id": "metric-carriage-bolt",
  "name": "Metric Carriage Bolt",
  "version": "1.0.0",
  "description": "Round head square neck carriage bolt",
  "parameters": {
    "size": {
      "label": "Metric Size",
      "type": "select",
      "options": [
        "M3",
        "M4",
        "M5",
        "M6",
        "M8",
        "M10",
        "M12"
      ],
      "default": "M6",
      "group": "dimensions"
    },
    "length": {
      "label": "Length",
      "default": 30,
      "min": 10,
      "max": 150,
      "step": 5,
      "unit": "mm",
      "group": "dimensions"
    }
  },
  "derived": {
    "major_diameter": {
      "formula": "ISO_MAJOR[size]",
      "description": "Diameter"
    },
    "radius": {
      "formula": "major_diameter / 2",
      "description": "Radius"
    },
    "head_dia": {
      "formula": "major_diameter * 1.75",
      "description": "Head diameter"
    },
    "head_radius": {
      "formula": "head_dia / 2",
      "description": "Head radius"
    },
    "head_height": {
      "formula": "major_diameter * 0.6",
      "description": "Head height"
    },
    "pitch": {
      "formula": "ISO_PITCH[size]",
      "description": "Pitch"
    }
  },
  "constants": {
    "ISO_MAJOR": {
      "M2": 2.0,
      "M2.5": 2.5,
      "M3": 3.0,
      "M4": 4.0,
      "M5": 5.0,
      "M6": 6.0,
      "M8": 8.0,
      "M10": 10.0,
      "M12": 12.0,
      "M16": 16.0,
      "M20": 20.0
    },
    "ISO_PITCH": {
      "M2": 0.4,
      "M2.5": 0.45,
      "M3": 0.5,
      "M4": 0.7,
      "M5": 0.8,
      "M6": 1.0,
      "M8": 1.25,
      "M10": 1.5,
      "M12": 1.75,
      "M16": 2.0,
      "M20": 2.5
    }
  },
  "geometry": {
    "shank": {
      "type": "cylinder",
      "radius": "radius",
      "height": "length",
      "position": [
        0,
        "-length / 2",
        0
      ]
    },
    "head": {
      "type": "sphere",
      "radius": "head_radius",
      "position": [
        0,
        "head_height * 0.2",
        0
      ]
    }
  },
  "groups": {
    "dimensions": {
      "label": "Dimensions",
      "order": 1
    }
  },
  "presets": {
    "m6x30": {
      "label": "M6x30",
      "values": {
        "size": "M6",
        "length": 30
      }
    }
  }
}