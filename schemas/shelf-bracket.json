{
  "id": "shelf-bracket",
  "name": "Shelf Bracket",
  "version": "1.0.0",
  "description": "L-shaped shelf bracket with optional diagonal gusset",

  "parameters": {
    "shelf_depth": {
      "label": "Shelf Depth", "default": 150, "min": 50, "max": 300,
      "step": 5, "unit": "mm", "group": "dimensions"
    },
    "height": {
      "label": "Wall Height", "default": 120, "min": 40, "max": 250,
      "step": 5, "unit": "mm", "group": "dimensions"
    },
    "thickness": {
      "label": "Thickness", "default": 5, "min": 2, "max": 15,
      "step": 1, "unit": "mm", "group": "dimensions"
    },
    "width": {
      "label": "Width", "default": 30, "min": 15, "max": 80,
      "step": 5, "unit": "mm", "group": "dimensions"
    },
    "gusset": {
      "label": "Diagonal Gusset", "type": "boolean", "default": true,
      "group": "structure"
    }
  },

  "derived": {
    "gusset_length": {
      "formula": "min(shelf_depth, height) * 0.6",
      "description": "Gusset diagonal length"
    },
    "gusset_offset_y": {
      "formula": "height - gusset_length * cos(PI / 4) / 2 - thickness",
      "description": "Gusset Y center position"
    },
    "gusset_offset_z": {
      "formula": "gusset_length * sin(PI / 4) / 2 + thickness",
      "description": "Gusset Z center position"
    }
  },

  "geometry": {
    "vertical": {
      "type": "box",
      "width": "width",
      "depth": "thickness",
      "height": "height",
      "position": [0, "height / 2", 0]
    },
    "horizontal": {
      "type": "box",
      "width": "width",
      "depth": "shelf_depth",
      "height": "thickness",
      "position": [0, "height - thickness / 2", "shelf_depth / 2"]
    },
    "gusset": {
      "type": "box",
      "width": "width - 1",
      "depth": "thickness",
      "height": "gusset_length",
      "position": [0, "gusset_offset_y", "gusset_offset_z"],
      "rotation": ["PI / 4", 0, 0],
      "visible": "gusset"
    }
  },

  "groups": {
    "dimensions": { "label": "Dimensions", "order": 1 },
    "structure": { "label": "Structure", "order": 2 }
  },

  "presets": {
    "small": {
      "label": "Small",
      "values": { "shelf_depth": 100, "height": 80, "width": 25 }
    },
    "medium": {
      "label": "Medium",
      "values": { "shelf_depth": 150, "height": 120, "width": 30 }
    },
    "heavy": {
      "label": "Heavy Duty",
      "values": { "shelf_depth": 200, "height": 150, "width": 40, "thickness": 8 }
    }
  }
}
