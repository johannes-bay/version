{
  "id": "metric-coupling-nut",
  "name": "Metric Coupling Nut",
  "version": "1.0.0",
  "description": "DIN 6334 long coupling nut",
  "parameters": {
    "size": {
      "label": "Metric Size",
      "type": "select",
      "options": [
        "M2",
        "M2.5",
        "M3",
        "M4",
        "M5",
        "M6",
        "M8",
        "M10",
        "M12",
        "M16",
        "M20"
      ],
      "default": "M6",
      "group": "dimensions"
    }
  },
  "derived": {
    "pitch": {
      "formula": "ISO_PITCH[size]",
      "description": "Thread pitch"
    },
    "major_diameter": {
      "formula": "ISO_MAJOR[size]",
      "description": "Nominal diameter"
    },
    "nut_af": {
      "formula": "ISO_HEX_AF[size]",
      "description": "Width across flats"
    },
    "nut_height": {
      "formula": "NUT_HEIGHT[size]",
      "description": "Nut height"
    },
    "outer_radius": {
      "formula": "nut_af / sqrt(3)",
      "description": "Circumscribed radius"
    },
    "bore_radius": {
      "formula": "major_diameter / 2",
      "description": "Bore radius"
    }
  },
