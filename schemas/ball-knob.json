{
  "id": "ball-knob",
  "name": "Ball Knob",
  "version": "1.0.0",
  "description": "Spherical ball knob with bore",
  "parameters": {
    "knob_dia": {
      "label": "Diameter",
      "default": 25,
      "min": 10,
      "max": 60,
      "step": 1,
      "unit": "mm",
      "group": "dimensions"
    },
    "bore_dia": {
      "label": "Bore",
      "default": 6,
      "min": 3,
      "max": 15,
      "step": 0.5,
      "unit": "mm",
      "group": "dimensions"
    },
    "stem_length": {
      "label": "Stem Length",
      "default": 15,
      "min": 5,
      "max": 40,
      "step": 1,
      "unit": "mm",
      "group": "dimensions"
    }
  },
  "derived": {
    "ball_radius": {
      "formula": "knob_dia / 2",
      "description": "Ball radius"
    },
    "stem_radius": {
      "formula": "bore_dia / 2 + 1",
      "description": "Stem radius"
    }
  },
  "geometry": {
    "ball": {
      "type": "sphere",
      "radius": "ball_radius",
      "position": [
        0,
        "ball_radius",
        0
      ]
    },
    "stem": {
      "type": "cylinder",
      "radius": "stem_radius",
      "height": "stem_length",
      "position": [
        0,
        "-stem_length / 2",
        0
      ]
    }
  },
  "groups": {
    "dimensions": {
      "label": "Dimensions",
      "order": 1
    }
  },
  "presets": {
    "default": {
      "label": "25mm",
      "values": {}
    }
  }
}